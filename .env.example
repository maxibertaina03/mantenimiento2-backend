# ───────── Base de datos (Supabase Postgres) ─────────
# Usamos Supabase SOLO como Postgres gestionado (ignoramos su Auth propio).
#
# DATABASE_URL -> connection string del POOLER (pgbouncer). La usa la app en runtime.
#   Importante: agregar ?pgbouncer=true para que Prisma no use prepared statements.
# DIRECT_URL   -> conexión DIRECTA (puerto 5432). La usa Prisma SOLO para migraciones.
#
# En Supabase: Project Settings -> Database -> Connection string.
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:TU_PASSWORD@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxxxxxxxxx:TU_PASSWORD@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# ───────── Servidor ─────────
PORT=3000

# ───────── CORS ─────────
# Origen del frontend permitido (Vite por defecto corre en 5173).
# Para varios orígenes, separar con coma: http://localhost:5173,https://miapp.com
FRONTEND_URL="http://localhost:5173"
